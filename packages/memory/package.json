{
  "name": "@wp-morph/memory",
  "version": "0.1.0",
  "description": "Knowledge persistence and retrieval for cross-session learning",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fightrons/wp-morph.git",
    "directory": "packages/memory"
  },
  "bugs": {
    "url": "https://github.com/fightrons/wp-morph/issues"
  },
  "homepage": "https://github.com/fightrons/wp-morph/tree/main/packages/memory#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "data"
  ],
  "dependencies": {
    "@wp-morph/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
