{
  "name": "@wp-morph/core",
  "version": "0.1.0",
  "description": "Core types and utilities for wp-morph",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fightrons/wp-morph.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/fightrons/wp-morph/issues"
  },
  "homepage": "https://github.com/fightrons/wp-morph/tree/main/packages/core#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
