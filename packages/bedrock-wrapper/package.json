{
  "name": "@wp-morph/bedrock-wrapper",
  "version": "0.1.0",
  "description": "Bedrock filesystem wrapper for wp-morph themes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fightrons/wp-morph.git",
    "directory": "packages/bedrock-wrapper"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@wp-morph/core": "workspace:*",
    "@wp-morph/wp-generator": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
