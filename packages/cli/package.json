{
  "name": "@wp-morph/cli",
  "version": "0.1.0",
  "description": "CLI for wp-morph WordPress development tool",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fightrons/wp-morph.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/fightrons/wp-morph/issues"
  },
  "homepage": "https://github.com/fightrons/wp-morph/tree/main/packages/cli#readme",
  "type": "module",
  "bin": {
    "wp-morph": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@wp-morph/core": "workspace:*",
    "@wp-morph/perception": "workspace:*",
    "@wp-morph/intelligence": "workspace:*",
    "@wp-morph/validation": "workspace:*",
    "@wp-morph/wp-generator": "workspace:*",
    "@wp-morph/bedrock-wrapper": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
